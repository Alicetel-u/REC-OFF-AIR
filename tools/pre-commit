#!/bin/bash
# pre-commit hook: コミット前にアセット・ボイス・スクリプトの整合性を自動チェック
# インストール: tools/setup-hooks.sh を実行

set -e

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'
errors=0

# ── 0. GDScript コンパイルチェック（.gd 変更時） ──
staged_gd=$(git diff --cached --name-only --diff-filter=ACM | grep '\.gd$' || true)
if [ -n "$staged_gd" ]; then
    # Godot 実行ファイルを探す（PATH → 既知の場所）
    GODOT=""
    if command -v godot &> /dev/null; then
        GODOT="godot"
    elif command -v godot.exe &> /dev/null; then
        GODOT="godot.exe"
    else
        # Windows デスクトップの既知パス
        for p in \
            "/c/Users/"*"/Desktop/Godot_v"*"_win64.exe/Godot_v"*"_console.exe" \
            "/c/Program Files/Godot/"*"console.exe"; do
            if [ -f "$p" ]; then
                GODOT="$p"
                break
            fi
        done
    fi

    if [ -n "$GODOT" ]; then
        echo "=== GDScript コンパイルチェック ==="
        # --headless --import で起動し、SCRIPT ERROR を検出
        compile_output=$("$GODOT" --headless --import --path . 2>&1 || true)
        script_errors=$(echo "$compile_output" | grep -c "SCRIPT ERROR" || true)
        if [ "$script_errors" -gt 0 ]; then
            echo -e "${RED}ERROR: GDScript コンパイルエラーが ${script_errors} 件あります${NC}"
            echo "$compile_output" | grep -A2 "SCRIPT ERROR"
            errors=$((errors + 1))
        else
            echo -e "${GREEN}OK: GDScript コンパイル成功${NC}"
        fi
    else
        echo -e "${YELLOW}WARN: Godot が見つかりません — GDScript チェックをスキップ${NC}"
    fi
fi

# ── 1. WAV変更時に.importファイルがステージされているか ──
staged_wavs=$(git diff --cached --name-only --diff-filter=ACM | grep '\.wav$' || true)
if [ -n "$staged_wavs" ]; then
    for wav in $staged_wavs; do
        import_file="${wav}.import"
        if [ -f "$import_file" ]; then
            # .importファイルに未ステージの変更がある場合のみエラー
            if git diff --name-only | grep -qF "$import_file"; then
                echo -e "${RED}ERROR: $wav が変更されていますが ${import_file} がステージされていません${NC}"
                echo "  → godot.exe --headless --import を実行してから git add ${import_file}"
                errors=$((errors + 1))
            fi
        else
            echo -e "${YELLOW}WARN: ${import_file} が存在しません（Godotエディタで再importが必要）${NC}"
            errors=$((errors + 1))
        fi
    done
fi

# ── 2. dialogue JSONが変更されている場合、バリデーション実行 ──
staged_json=$(git diff --cached --name-only --diff-filter=ACM | grep 'dialogue/.*\.json$' || true)
if [ -n "$staged_json" ]; then
    if command -v python &> /dev/null && [ -f "tools/fix_voice_wait.py" ]; then
        echo "=== ボイスバリデーション実行中 ==="
        output=$(python tools/fix_voice_wait.py --validate-only 2>&1 || true)
        echo "$output"

        # MISSING_WAV があればエラー（致命的な問題）
        # CONSECUTIVE_WAIT は演出意図の場合があるためブロックしない
        if echo "$output" | grep -qE "MISSING_WAV"; then
            echo -e "${RED}ERROR: 致命的なバリデーション警告があります。修正してからコミットしてください${NC}"
            errors=$((errors + 1))
        fi
    fi

    # dialogue_cache.js を自動再生成（パスビューア用）
    PYTHON=""
    for p in python python3 \
        "$HOME/AppData/Local/Python/bin/python.exe" \
        "$HOME/AppData/Local/Programs/Python/Python312/python.exe" \
        "$HOME/AppData/Local/Programs/Python/Python311/python.exe"; do
        if command -v "$p" &> /dev/null 2>&1 || [ -f "$p" ]; then
            PYTHON="$p"
            break
        fi
    done
    if [ -n "$PYTHON" ] && [ -f "tools/path-viewer/update_cache.py" ]; then
        echo "=== dialogue_cache.js 再生成 ==="
        "$PYTHON" tools/path-viewer/update_cache.py
        git add tools/path-viewer/dialogue_cache.js
        echo -e "${GREEN}OK: dialogue_cache.js を更新しました${NC}"
    fi
fi

# ── 3. CLAUDE.mdの設定値とコードの整合性チェック ──
staged_tools=$(git diff --cached --name-only | grep -E 'tools/(generate_voice|fix_voice|trim_voice)' || true)
if [ -n "$staged_tools" ]; then
    if ! git diff --cached --name-only | grep -qF "CLAUDE.md"; then
        echo -e "${YELLOW}WARN: ボイスツールが変更されていますが CLAUDE.md がステージされていません${NC}"
        echo "  → 設定値を変更した場合は CLAUDE.md も更新してください"
    fi
fi

if [ $errors -gt 0 ]; then
    echo ""
    echo -e "${RED}コミットを中止しました（${errors}件のエラー）${NC}"
    exit 1
fi
